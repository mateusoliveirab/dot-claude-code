{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "BASH_MAX_OUTPUT_LENGTH": "30000",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "includeGitInstructions": false,
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__fill",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__emulate",
      "mcp__chrome-devtools__resize_page",
      "mcp__chrome-devtools__wait_for",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__new_page",
      "mcp__shadcn-ui__get_component",
      "Bash(npm run lint:*)",
      "Bash(npx eslint:*)",
      "Bash(pkill:*)"
    ],
    "defaultMode": "default",
    "ask": [
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(docker *)",
      "Bash(kubectl *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Read(.env)",
      "Read(.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/credentials.json)",
      "Write(**/secrets.json)"
    ],
    "alwaysAllow": [
      {
        "tool": "Read",
        "pathPattern": "src/**/*"
      },
      {
        "tool": "Read",
        "pathPattern": "app/**/*"
      },
      {
        "tool": "Read",
        "pathPattern": "components/**/*"
      },
      {
        "tool": "Read",
        "pathPattern": "lib/**/*"
      },
      {
        "tool": "Read",
        "pathPattern": "*.md"
      },
      {
        "tool": "Read",
        "pathPattern": "*.json"
      },
      {
        "tool": "Grep",
        "pathPattern": "**/*.ts"
      },
      {
        "tool": "Grep",
        "pathPattern": "**/*.tsx"
      },
      {
        "tool": "Grep",
        "pathPattern": "**/*.js"
      },
      {
        "tool": "Grep",
        "pathPattern": "**/*.jsx"
      },
      {
        "tool": "Glob",
        "pathPattern": "**/*"
      },
      {
        "tool": "Bash",
        "prompt": "run linting"
      },
      {
        "tool": "Bash",
        "prompt": "run type checking"
      },
      {
        "tool": "Bash",
        "prompt": "run tests"
      },
      {
        "tool": "Bash",
        "prompt": "check git status"
      },
      {
        "tool": "Bash",
        "prompt": "show git diff"
      },
      {
        "tool": "Bash",
        "prompt": "show git log"
      }
    ],
    "alwaysDeny": [
      {
        "tool": "Bash",
        "prompt": "force delete files or directories"
      },
      {
        "tool": "Bash",
        "prompt": "force push to git"
      },
      {
        "tool": "Write",
        "pathPattern": ".env"
      },
      {
        "tool": "Write",
        "pathPattern": ".env.*"
      },
      {
        "tool": "Write",
        "pathPattern": "**/credentials.json"
      },
      {
        "tool": "Write",
        "pathPattern": "**/secrets.json"
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "promptSuggestionEnabled": false,
  "voiceEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "playground@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Claude Code needs your attention'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | (read -r f && { [[ \"$f\" == *.sh ]] || exit 0; bash -n \"$f\"; }) 2>/dev/null",
            "timeout": 10,
            "statusMessage": "Checking shell syntax..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | (read -r f && { [[ \"$f\" == *.json ]] || exit 0; jq empty \"$f\"; }) 2>/dev/null",
            "timeout": 10,
            "statusMessage": "Validating JSON..."
          }
        ]
      }
    ]
  }
}